# Copy this file to ".env" and fill in your real values:
#   cp .env.example .env
# The real .env is gitignored, so your secrets never get committed.

# Your Notion internal integration token (starts with ntn_)
NOTION_TOKEN=ntn_paste_your_token_here

# Your job-tracker database id (32-char string before the ? in the DB url)
NOTION_DATABASE_ID=38cbe477358e80f0a0edcf40a797436e

# --- Optional knobs ---
# true = classify & print only, no writes to Notion and no Gmail labels.
DRY_RUN=false
# How many days back to scan the inbox.
LOOKBACK_DAYS=30
